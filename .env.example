# === Database (Vercel Postgres) ===
POSTGRES_URL=postgres://...

# === Auth (NextAuth v5) ===
AUTH_SECRET=openssl-rand-hex-32-here
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# === Assess LLM Provider ===
ASSESS_LLM_PROVIDER=anthropic
ASSESS_ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ASSESS_ANTHROPIC_MODEL=MiniMax-M2.7-highspeed
ASSESS_ANTHROPIC_API_KEY=sk-your-key-here

# Fallback: OpenAI-compatible (Ollama)
# ASSESS_LLM_BASE_URL=http://localhost:11434/v1
# ASSESS_LLM_MODEL=gemma3
# ASSESS_LLM_API_KEY=ollama

# === Refresh Pipeline LLM ===
REFRESH_LLM_BASE_URL=https://api.minimax.chat/v1
REFRESH_LLM_MODEL=MiniMax-M1
REFRESH_LLM_API_KEY=sk-your-key-here
REFRESH_LLM_MAX_RPM=30

# Fallback (optional)
# REFRESH_LLM_FALLBACK_BASE_URL=https://api.anthropic.com/v1
# REFRESH_LLM_FALLBACK_MODEL=claude-sonnet-4-20250514
# REFRESH_LLM_FALLBACK_API_KEY=sk-your-key-here

# === Web Search Provider ===
REFRESH_SEARCH_PROVIDER=brave
REFRESH_SEARCH_API_KEY=your-search-api-key

# === Pipeline Settings ===
REFRESH_CONCURRENCY=3

# === GitHub (for refresh dispatch) ===
GITHUB_TOKEN=ghp_your-token
GITHUB_REPO=thetangstr/agent-factory-research

# === CORS (comma-separated origins for AgentDash) ===
CORS_ALLOWED_ORIGINS=http://localhost:3100,https://your-agentdash.com
